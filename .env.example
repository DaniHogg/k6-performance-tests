# Environment variables for k6 performance tests

# Target environment (dev, staging, prod)
ENV=staging

# Base URL of API to test
BASE_URL=https://api-staging.example.com

# API endpoint prefix
API_ENDPOINT=/api/v1

# Request timeout
TIMEOUT=30s

# Test credentials (if needed)
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=password123

# k6 Cloud configuration (optional)
# K6_CLOUD_PROJECT_ID=3330657
# K6_CLOUD_TOKEN=your-token-here
